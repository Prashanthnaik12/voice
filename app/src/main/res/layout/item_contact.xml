<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_bg"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <TextView android:id="@+id/tvName"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="#E2E8F0" android:textSize="15sp" android:textStyle="bold"/>

    <TextView android:id="@+id/tvNumber"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="#93C5FD" android:textSize="13sp"/>

    <TextView android:id="@+id/tvNicknames"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="#64748B" android:textSize="12sp"/>

</LinearLayout>
